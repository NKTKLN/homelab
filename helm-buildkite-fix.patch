diff --git a/ansible/roles/kubernetes_tools/tasks/tools.yml b/ansible/roles/kubernetes_tools/tasks/tools.yml
index 92f8c08..22ba7ec 100644
--- a/ansible/roles/kubernetes_tools/tasks/tools.yml
+++ b/ansible/roles/kubernetes_tools/tasks/tools.yml
@@ -1,16 +1,62 @@
-# Helm — installed from the official apt repository.
-- name: Download Helm GPG key
+# Helm — installed from the community-maintained apt repository.
+- name: Ensure apt keyrings directory exists
+  ansible.builtin.file:
+    path: /etc/apt/keyrings
+    state: directory
+    mode: "0755"
+  when: kubernetes_install_helm | bool
+
+- name: Ensure Helm repository dependencies are installed
+  ansible.builtin.apt:
+    name:
+      - apt-transport-https
+      - gpg
+    state: present
+    update_cache: true
+    cache_valid_time: 3600
+  when: kubernetes_install_helm | bool
+
+- name: Download Helm Buildkite GPG key
   ansible.builtin.get_url:
-    url: https://baltocdn.com/helm/signing.asc
-    dest: /etc/apt/keyrings/helm.asc
+    url: https://packages.buildkite.com/helm-linux/helm-debian/gpgkey
+    dest: /etc/apt/keyrings/helm-buildkite.asc
     mode: "0644"
     timeout: 60
+  register: helm_buildkite_key
+  when: kubernetes_install_helm | bool
+
+- name: Verify Helm Buildkite GPG key fingerprint
+  ansible.builtin.command: >-
+    gpg --show-keys --with-colons /etc/apt/keyrings/helm-buildkite.asc
+  register: helm_buildkite_key_info
+  changed_when: false
+  failed_when: >-
+    'DDF78C3E6EBB2D2CC223C95C62BA89D07698DBC6' not in helm_buildkite_key_info.stdout
+  when: kubernetes_install_helm | bool
+
+- name: Check Helm Buildkite keyring
+  ansible.builtin.stat:
+    path: /etc/apt/keyrings/helm-buildkite.gpg
+  register: helm_buildkite_keyring
+  when: kubernetes_install_helm | bool
+
+- name: Dearmor Helm Buildkite GPG key
+  ansible.builtin.command: >-
+    gpg --dearmor --yes -o /etc/apt/keyrings/helm-buildkite.gpg /etc/apt/keyrings/helm-buildkite.asc
+  when:
+    - kubernetes_install_helm | bool
+    - helm_buildkite_key.changed or not helm_buildkite_keyring.stat.exists
+
+- name: Remove legacy Helm GPG key
+  ansible.builtin.file:
+    path: /etc/apt/keyrings/helm.asc
+    state: absent
   when: kubernetes_install_helm | bool
 
 - name: Add Helm repository
   ansible.builtin.apt_repository:
     repo: >-
-      deb [signed-by=/etc/apt/keyrings/helm.asc] https://baltocdn.com/helm/stable/debian/ all main
+      deb [signed-by=/etc/apt/keyrings/helm-buildkite.gpg] https://packages.buildkite.com/helm-linux/helm-debian/any/ any main
     filename: helm
     state: present
     update_cache: true
