diff --git a/ansible/roles/kubernetes_tools/tasks/helm_cleanup.yml b/ansible/roles/kubernetes_tools/tasks/helm_cleanup.yml
new file mode 100644
index 0000000..8f1b120
--- /dev/null
+++ b/ansible/roles/kubernetes_tools/tasks/helm_cleanup.yml
@@ -0,0 +1,27 @@
+# Remove references to Helm's former Balto APT mirror before any apt cache update.
+# The domain is no longer a Helm mirror and may cause apt-secure failures.
+- name: Find APT source files
+  ansible.builtin.find:
+    paths: /etc/apt/sources.list.d
+    patterns:
+      - "*.list"
+      - "*.sources"
+    file_type: file
+  register: helm_apt_source_files
+  when: kubernetes_install_helm | bool
+
+- name: Check main APT sources file
+  ansible.builtin.stat:
+    path: /etc/apt/sources.list
+  register: helm_main_sources
+  when: kubernetes_install_helm | bool
+
+- name: Remove legacy Helm baltocdn APT entries
+  ansible.builtin.lineinfile:
+    path: "{{ item }}"
+    regexp: '.*baltocdn\.com/helm.*'
+    state: absent
+  loop: >-
+    {{ (helm_apt_source_files.files | default([]) | map(attribute='path') | list)
+       + (['/etc/apt/sources.list'] if helm_main_sources.stat.exists | default(false) else []) }}
+  when: kubernetes_install_helm | bool
